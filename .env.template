# =============================================================================
#  Environment variables – copy this file to ".env" and fill in the values.
#  NEVER commit the ".env" file to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure Bot Service credentials
# Obtain these from: Azure Portal → Bot Service resource → Configuration
# ---------------------------------------------------------------------------
MicrosoftAppId=
MicrosoftAppPassword=

# ---------------------------------------------------------------------------
# Azure AI Foundry
#
# Project endpoint – found in the Azure AI Foundry portal under:
#   Your project → Overview → Project endpoint
#   Format: https://<aiservices-id>.services.ai.azure.com/api/projects/<project-name>
# ---------------------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=

# ID of the agent to query
#   Found in: Azure AI Foundry portal → your project → Agents → <your agent> → Agent ID
AZURE_AI_AGENT_ID=

# ---------------------------------------------------------------------------
# App Service
# (Azure App Service sets PORT automatically – only override for local dev)
# ---------------------------------------------------------------------------
PORT=3978
